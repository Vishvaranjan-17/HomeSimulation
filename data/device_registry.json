    "goodmorning": [
      {"intent": "turn_on", "device": "light_bedroom"},
      {"intent": "turn_on", "device": "curtains_living"},
      {"intent": "turn_off", "device": "lock_front"}
    ],
    "movie time": [
      {"intent": "turn_off", "device": "light_living"},
      {"intent": "turn_on", "device": "tv_living"},
      {"intent": "turn_off", "device": "curtains_living"}
    ]
  }
